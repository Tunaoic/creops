# CreOps — Environment Variables
# Copy to .env.local and paste your keys.
# All keys are OPTIONAL — app works in dev mode (cookie impersonation + local
# SQLite) without any. Set them to flip into production mode.
#
# Quick start (no keys):  pnpm db:reset && pnpm dev
# Production deploy:      see DEPLOY.md

# ============================================================================
# Clerk Auth — REAL signup / login (replaces cookie impersonation)
# Without these, app runs in dev mode: top-bar "As Trang ▾" switcher visible,
# anyone can pick any user. With keys, real auth + /sign-in /sign-up pages.
# Sign up: https://dashboard.clerk.com → New application
# ============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook secret — Clerk dashboard → Webhooks → Endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=

# Optional Clerk redirect overrides (defaults are sensible)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ============================================================================
# Database — local SQLite by default
# For production (Round 1b: cloud DB):
#   DATABASE_URL=libsql://<your-db>.turso.io
#   DATABASE_AUTH_TOKEN=<from Turso dashboard>
# Sign up Turso: https://turso.tech → New database
# Note: cloud DB requires async query refactor — tracked in DEPLOY.md.
# ============================================================================
# DATABASE_URL=
# DATABASE_AUTH_TOKEN=

# ============================================================================
# Claude API — REAL AI generation (titles, descriptions, cuts, posts, threads)
# Without this key, AI generates use mock outputs from src/lib/ai-mock.ts.
# Cost: ~$0.20-0.30 per topic (5 deliverables, full generation).
# Sign up: https://console.anthropic.com → API keys
# ============================================================================
ANTHROPIC_API_KEY=

# Optional model overrides (defaults are sensible)
# CLAUDE_MODEL_LONG=claude-sonnet-4-6   # used for description, blog, cuts, post copy, thread
# CLAUDE_MODEL_SHORT=claude-haiku-4-5   # used for title suggestions, tags

# ============================================================================
# OpenAI Whisper API — REAL video/audio transcription
# Without this, uploaded videos get a mock placeholder transcript.
# Cost: $0.006/minute. 15-min video = $0.09.
# Sign up: https://platform.openai.com → API keys
# ============================================================================
OPENAI_API_KEY=

# ============================================================================
# Cloudflare R2 — REAL file storage (videos, images)
# Without these 4, uploads use local file system (./local-uploads/).
# Free 10GB + zero egress. After: $0.015/GB/month.
# Sign up: https://dash.cloudflare.com → R2 → Create bucket → Manage API Tokens
# ============================================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional: custom domain for public URLs (otherwise uses internal R2 URL)
# R2_PUBLIC_URL=https://media.yourdomain.com

# ============================================================================
# Resend — Email invites (workspace member onboarding)
# Without this key, inviteMember() logs the join URL to the server console
# (dev fallback) instead of actually delivering an email. The invite row
# is still written to the DB so /join/[token] still works for testing.
# Sign up: https://resend.com → free tier 100 emails/day, 3000/month
# Optional: RESEND_FROM_EMAIL — defaults to "CreOps <onboarding@resend.dev>"
#   Set this once you verify your own domain.
# ============================================================================
RESEND_API_KEY=
# RESEND_FROM_EMAIL=CreOps <invites@yourdomain.com>

# ============================================================================
# Public app URL — used by inviteMember() to build absolute /join/<token>
# links in the emailed invite. Vercel auto-provides VERCEL_PROJECT_PRODUCTION_URL
# as a fallback, but set NEXT_PUBLIC_APP_URL once you wire your custom domain.
# Local dev defaults to http://localhost:3000.
# ============================================================================
# NEXT_PUBLIC_APP_URL=https://creops.app

# ============================================================================
# (Future — not yet wired in this prototype)
# ============================================================================
# STRIPE_SECRET_KEY=                    # Billing
